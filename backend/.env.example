DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL_TEST=postgresql://user:password@host/dbname_test?sslmode=require
JWT_SECRET=your_jwt_secret_here_min_32_chars
REFRESH_SECRET=your_refresh_secret_here_min_32_chars
CLIENT_URL=http://localhost:5173
PORT=5000
NODE_ENV=development

# Groq (AI update bar — free tier)
GROQ_API_KEY=gsk_...

# CalDAV / iCloud sync (optional — app works without this)
CALDAV_URL=https://caldav.icloud.com
CALDAV_USERNAME=your-apple-id@icloud.com
CALDAV_PASSWORD=xxxx-xxxx-xxxx-xxxx
CALDAV_CALENDAR_PATH=/dav/calendars/your-apple-id@icloud.com/personal/
